' XLS FILE COMPARATOR WITH KEY-BASED MATCHING - VBA Module
' + ' Purpose: Compare two XLS files using key columns and compare cohering attributes
' + ' Usage: Run CompareXLSFilesWithKeys() subroutine
' + ' Features: Matches rows by key columns, compares attributes for matching keys

Option Explicit

' + '
' + ' ============================================================================
' + ' MAIN SUBROUTINE - START HERE
' + ' ============================================================================

Sub CompareXLSFilesWithKeys()
    
    ' Main procedure to compare two XLS files using key-based matching
    ' Configure file paths and key columns before running
    
    Dim file1Path As String
    Dim file2Path As String
    Dim outputPath As String
    Dim keyColumns As String
    Dim attributeColumns As String
    
    ' CONFIGURE THESE PATHS AND COLUMNS:
    file1Path = "C:\Users\YourName\Documents\file1.xlsx"
    file2Path = "C:\Users\YourName\Documents\file2.xlsx"
    outputPath = "C:\Users\YourName\Documents\comparison_report.txt"
    
    ' Key columns (comma-separated, case-sensitive): Used to match records
    keyColumns = "ID,Product"
    
    ' Attribute columns (comma-separated): Columns to compare for matching keys
    attributeColumns = "Price,Quantity,Status,LastUpdated"
    
    ' Run comparison
    Dim comparator As New XLSComparator
    comparator.CompareFilesWithKeys file1Path, file2Path, outputPath, keyColumns, attributeColumns
    
    MsgBox "Comparison complete! Report saved to:" & vbCrLf & outputPath, vbInformation, "Comparison Complete"
    
End Sub

