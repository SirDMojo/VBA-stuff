Option Explicit

Public file1Path As String
Public file2Path As String
Public file1Name As String
Public file2Name As String

Public wb1 As Workbook
Public wb2 As Workbook
Public ws1 As Worksheet
Public ws2 As Worksheet

Public keyColumnNames() As String
Public attributeColumnNames() As String
Public keyColumnIndices() As Long
Public attributeColumnIndices() As Long

Public reportData As New Collection
Public matchedRecords As New Collection
Public recordsOnlyInFile1 As New Collection
Public recordsOnlyInFile2 As New Collection
Public attributeDifferences As New Collection

Private Function GetWorkbookName(filePath As String) As String
    Dim parts() As String
    parts = Split(filePath, "\")
    GetWorkbookName = parts(UBound(parts))
End Function

Private Function SplitColumns(columnString As String) As String()
    
    ' Split comma-separated column names into array
    
    Dim parts() As String
    Dim result() As String
    Dim i As Long
    Dim cleanedParts() As String
    
    parts = Split(columnString, ",")
    ReDim cleanedParts(LBound(parts) To UBound(parts))
    
    For i = LBound(parts) To UBound(parts)
        cleanedParts(i) = Trim(parts(i))
    Next i
    
    SplitColumns = cleanedParts
End Function

Public Sub CompareFilesWithKeys(path1 As String, path2 As String, outputPath As String, keys As String, attributes As String)
    
    ' Main comparison procedure using key-based matching
    
    On Error GoTo ErrorHandler
    
    file1Path = path1
    file2Path = path2
    file1Name = GetWorkbookName(path1)
    file2Name = GetWorkbookName(path2)
    
    ' Parse column names
    keyColumnNames = SplitColumns(keys)
    attributeColumnNames = SplitColumns(attributes)
    
    ' Load files
    If Not LoadFiles() Then Exit Sub
    
    ' Find column indices
    If Not FindColumnIndices() Then Exit Sub
    
    ' Run key-based comparison
    Call CompareSchemas
    Call CompareDimensions
    Call FindMatchingRecords
    Call FindDifferentAttributes
    
    ' Generate reports
    Call GenerateSummaryReport(outputPath)
    Call ExportDetailedReport
    
    ' Close workbooks
    wb1.Close False
    wb2.Close False
    
    Exit Sub
ErrorHandler:
    MsgBox "Error: " & Err.Description, vbCritical, "Comparison Error"
End Sub

Private Function LoadFiles() As Boolean
    
    ' Load both XLS files
    
    On Error GoTo ErrorHandler
    
    Set wb1 = Workbooks.Open(file1Path)
    Set ws1 = wb1.Sheets(1)
    
    Set wb2 = Workbooks.Open(file2Path)
    Set ws2 = wb2.Sheets(1)
    
    MsgBox "✓ Loaded " & file1Name & vbCrLf & "✓ Loaded " & file2Name, vbInformation, "Files Loaded"
    LoadFiles = True
    Exit Function
    
ErrorHandler:
    MsgBox "Error loading files: " & Err.Description, vbCritical, "Load Error"
    LoadFiles = False
End Function

Private Function FindColumnIndices() As Boolean
    
    ' Find the column indices for key and attribute columns
    
    Dim i As Long, j As Long
    Dim col As Long
    Dim lastCol As Long: lastCol = GetLastColumn(ws1)
    Dim found As Boolean
    Dim colName As String
    
    ' Find key column indices
    ReDim keyColumnIndices(LBound(keyColumnNames) To UBound(keyColumnNames))
    For i = LBound(keyColumnNames) To UBound(keyColumnNames)
        found = False
        For col = 1 To lastCol
            colName = CStr(ws1.Cells(1, col).Value)
            If colName = keyColumnNames(i) Then
                keyColumnIndices(i) = col
                found = True
                Exit For
            End If
        Next col
        If Not found Then
            MsgBox "Key column '" & keyColumnNames(i) & "' not found in " & file1Name, vbCritical, "Column Not Found"
            FindColumnIndices = False
            Exit Function
        End If
    Next i
    
    ' Find attribute column indices
    ReDim attributeColumnIndices(LBound(attributeColumnNames) To UBound(attributeColumnNames))
    For i = LBound(attributeColumnNames) To UBound(attributeColumnNames)
        found = False
        For col = 1 To lastCol
            colName = CStr(ws1.Cells(1, col).Value)
            If colName = attributeColumnNames(i) Then
                attributeColumnIndices(i) = col
                found = True
                Exit For
            End If
        Next col
        If Not found Then
            MsgBox "Attribute column '" & attributeColumnNames(i) & "' not found in " & file1Name, vbCritical, "Column Not Found"
            FindColumnIndices = False
            Exit Function
        End If
    Next i
    
    FindColumnIndices = True
End Function

Private Function GetKeyValue(ws As Worksheet, rowNum As Long) As String
    
    ' Get concatenated key value for a row
    
    Dim i As Long
    Dim keyValue As String: keyValue = ""
    
    For i = LBound(keyColumnIndices) To UBound(keyColumnIndices)
        keyValue = keyValue & "|" & CStr(ws.Cells(rowNum, keyColumnIndices(i)).Value)
    Next i
    
    GetKeyValue = keyValue
End Function

Private Function GetAttributeValues(ws As Worksheet, rowNum As Long) As Collection
    
    ' Get all attribute values for a row
    
    Dim result As New Collection
    Dim i As Long
    
    For i = LBound(attributeColumnIndices) To UBound(attributeColumnIndices)
        result.Add CStr(ws.Cells(rowNum, attributeColumnIndices(i)).Value)
    Next i
    
    Set GetAttributeValues = result
End Function

Private Sub CompareSchemas()
    
    ' Compare table schemas (columns)
    
    Dim col1 As Long, col2 As Long
    Dim cols1 As Collection, cols2 As Collection
    Dim i As Long, j As Long
    Dim foundCol As Boolean
    
    Set cols1 = GetColumnHeaders(ws1)
    Set cols2 = GetColumnHeaders(ws2)
    
    reportData.Add "SCHEMA COMPARISON:"
    reportData.Add "================================================================"
    reportData.Add ""
    
    ' Key Columns
    reportData.Add "Key Columns:"
    For i = LBound(keyColumnNames) To UBound(keyColumnNames)
        reportData.Add "  - " & keyColumnNames(i)
    Next i
    
    reportData.Add ""
    
    ' Attribute Columns
    reportData.Add "Attribute Columns (for comparison):"
    For i = LBound(attributeColumnNames) To UBound(attributeColumnNames)
        reportData.Add "  - " & attributeColumnNames(i)
    Next i
    
    reportData.Add ""
    
End Sub

Private Sub CompareDimensions()
    
    ' Compare table dimensions (rows and columns)
    
    Dim rows1 As Long, rows2 As Long
    Dim cols1 As Long, cols2 As Long
    
    rows1 = GetLastRow(ws1)
    rows2 = GetLastRow(ws2)
    cols1 = GetLastColumn(ws1)
    cols2 = GetLastColumn(ws2)
    
    reportData.Add "DIMENSIONS COMPARISON:"
    reportData.Add "================================================================"
    reportData.Add ""
    reportData.Add file1Name & " Data Rows: " & (rows1 - 1)
    reportData.Add file2Name & " Data Rows: " & (rows2 - 1)
    reportData.Add "Row Difference: " & ((rows2 - 1) - (rows1 - 1))
    reportData.Add ""
    
End Sub

Private Sub FindMatchingRecords()
    
    ' Find records with matching keys in both files
    
    Dim i As Long, j As Long
    Dim rows1 As Long, rows2 As Long
    Dim key1 As String, key2 As String
    Dim found As Boolean
    
    rows1 = GetLastRow(ws1)
    rows2 = GetLastRow(ws2)
    
    reportData.Add "KEY-BASED MATCHING ANALYSIS:"
    reportData.Add "================================================================"
    reportData.Add ""
    
    Dim matchedCount As Long: matchedCount = 0
    Dim onlyInFile1Count As Long: onlyInFile1Count = 0
    Dim onlyInFile2Count As Long: onlyInFile2Count = 0
    
    ' Find records only in file 1
    For i = 2 To rows1
        key1 = GetKeyValue(ws1, i)
        found = False
        For j = 2 To rows2
            key2 = GetKeyValue(ws2, j)
            If key1 = key2 Then
                found = True
                matchedCount = matchedCount + 1
                matchedRecords.Add "File1_Row=" & i & "|File2_Row=" & j & "|Key=" & key1
                Exit For
            End If
        Next j
        If Not found Then
            onlyInFile1Count = onlyInFile1Count + 1
            If onlyInFile1Count <= 5 Then
                recordsOnlyInFile1.Add "Row " & i & " - Key: " & key1
            End If
        End If
    Next i
    
    ' Find records only in file 2
    For j = 2 To rows2
        key2 = GetKeyValue(ws2, j)
        found = False
        For i = 2 To rows1
            key1 = GetKeyValue(ws1, i)
            If key1 = key2 Then
                found = True
                Exit For
            End If
        Next i
        If Not found Then
            onlyInFile2Count = onlyInFile2Count + 1
            If onlyInFile2Count <= 5 Then
                recordsOnlyInFile2.Add "Row " & j & " - Key: " & key2
            End If
        End If
    Next j
    
    reportData.Add "Matched Records (same key): " & matchedCount
    reportData.Add ""
    reportData.Add "Records only in " & file1Name & ": " & onlyInFile1Count
    For i = 1 To recordsOnlyInFile1.Count
        reportData.Add "  " & recordsOnlyInFile1(i)
    Next i
    If onlyInFile1Count > 5 Then
        reportData.Add "  ... and " & (onlyInFile1Count - 5) & " more"
    End If
    
    reportData.Add ""
    
    reportData.Add "Records only in " & file2Name & ": " & onlyInFile2Count
    For i = 1 To recordsOnlyInFile2.Count
        reportData.Add "  " & recordsOnlyInFile2(i)
    Next i
    If onlyInFile2Count > 5 Then
        reportData.Add "  ... and " & (onlyInFile2Count - 5) & " more"
    End If
    
    reportData.Add ""
    
End Sub

Private Sub FindDifferentAttributes()
    
    ' Compare attributes for records with matching keys
    
    Dim i As Long, j As Long, k As Long
    Dim matchInfo As String
    Dim row1 As Long, row2 As Long
    Dim matchArray() As String
    Dim attrs1 As Collection, attrs2 As Collection
    Dim diffCount As Long: diffCount = 0
    
    reportData.Add "ATTRIBUTE DIFFERENCES (for matched keys):"
    reportData.Add "================================================================"
    reportData.Add ""
    
    For i = 1 To matchedRecords.Count
        matchInfo = matchedRecords(i)
        
        ' Parse match info
        row1 = CLng(Mid(matchInfo, InStr(matchInfo, "File1_Row=") + 10, InStr(matchInfo, "|File2_Row") - (InStr(matchInfo, "File1_Row=") + 10)))
        row2 = CLng(Mid(matchInfo, InStr(matchInfo, "File2_Row=") + 10, InStr(matchInfo, "|Key") - (InStr(matchInfo, "File2_Row=") + 10)))
        
        ' Get attribute values
        Set attrs1 = GetAttributeValues(ws1, row1)
        Set attrs2 = GetAttributeValues(ws2, row2)
        
        ' Compare attributes
        Dim hasChanges As Boolean: hasChanges = False
        For k = 1 To attrs1.Count
            If CStr(attrs1(k)) <> CStr(attrs2(k)) Then
                hasChanges = True
                diffCount = diffCount + 1
                If diffCount <= 20 Then
                    Dim keyVal As String
                    keyVal = Mid(matchInfo, InStr(matchInfo, "Key=") + 4)
                    attributeDifferences.Add "Key: " & keyVal & " | " & attributeColumnNames(k - 1) & ": '" & attrs1(k) & "' → '" & attrs2(k) & "'"
                End If
            End If
        Next k
    Next i
    
    reportData.Add "Total Attribute Differences: " & diffCount
    For i = 1 To attributeDifferences.Count
        reportData.Add "  " & attributeDifferences(i)
    Next i
    If diffCount > 20 Then
        reportData.Add "  ... and " & (diffCount - 20) & " more differences"
    End If
    
    reportData.Add ""
    
End Sub

Private Function GetColumnHeaders(ws As Worksheet) As Collection
    
    ' Get all column headers from first row
    
    Dim result As New Collection
    Dim col As Long
    Dim lastCol As Long: lastCol = GetLastColumn(ws)
    
    For col = 1 To lastCol
        Dim headerVal As Variant: headerVal = ws.Cells(1, col).Value
        If Not IsEmpty(headerVal) Then
            result.Add CStr(headerVal)
        End If
    Next col
    
    Set GetColumnHeaders = result
End Function

Private Function GetLastRow(ws As Worksheet) As Long
    
    ' Find last row with data
    
    Dim lastRow As Long
    On Error Resume Next
    lastRow = ws.Cells.SpecialCells(xlCellTypeLastCell).Row
    On Error GoTo 0
    GetLastRow = lastRow
End Function

Private Function GetLastColumn(ws As Worksheet) As Long
    
    ' Find last column with data
    
    Dim lastCol As Long
    On Error Resume Next
    lastCol = ws.Cells.SpecialCells(xlCellTypeLastCell).Column
    On Error GoTo 0
    GetLastColumn = lastCol
End Function

Private Sub GenerateSummaryReport(outputPath As String)
    
    ' Generate summary report and save to file
    
    Dim fso As Object
    Dim file As Object
    Dim i As Long
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set file = fso.CreateTextFile(outputPath, True)
    
    ' Write header
    file.WriteLine "================================================================================"
    file.WriteLine "XLS FILE COMPARISON REPORT (KEY-BASED MATCHING)"
    file.WriteLine "================================================================================"
    file.WriteLine "Generated: " & Now
    file.WriteLine ""
    file.WriteLine "FILE INFORMATION:"
    file.WriteLine "--------------------------------------------------------------------------------"
    file.WriteLine "File 1: " & file1Name
    file.WriteLine "File 2: " & file2Name
    file.WriteLine ""
    
    ' Write report data
    For i = 1 To reportData.Count
        file.WriteLine reportData(i)
    Next i
    
    ' Write summary
    file.WriteLine "SUMMARY:"
    file.WriteLine "================================================================================"
    file.WriteLine "Key-based comparison complete - Review details above"
    file.WriteLine "================================================================================"
    
    file.Close
    Set file = Nothing
    Set fso = Nothing
    
    MsgBox "Summary report saved to:" & vbCrLf & outputPath, vbInformation, "Report Saved"
End Sub

Private Sub ExportDetailedReport()
    
    ' Export detailed report to Excel sheet
    
    Dim newWb As Workbook
    Dim newWs As Worksheet
    Dim row As Long
    Dim i As Long
    
    Set newWb = Workbooks.Add
    Set newWs = newWb.Sheets(1)
    newWs.Name = "Comparison Report"
    
    ' Add report data
    row = 1
    newWs.Cells(row, 1).Value = "Key-Based Comparison Report"
    newWs.Cells(row, 1).Font.Bold = True
    row = row + 1
    newWs.Cells(row, 1).Value = "Generated: " & Now
    row = row + 3
    
    For i = 1 To reportData.Count
        newWs.Cells(row, 1).Value = reportData(i)
        row = row + 1
    Next i
    
    newWs.Columns(1).AutoFit
    newWb.SaveAs ThisWorkbook.Path & "\comparison_detailed.xlsx"
    newWb.Close
End Sub

